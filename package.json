{
  "name": "open-pixel",
  "version": "0.1.0",
  "description": "AI-native Web3 pixel quest game: guest-first, no token economy, optional safe wallet proof.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Open Pixel contributors",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:vercel": "npm run build && rm -rf apps/web/dist/game apps/web/dist/spritesheets && mkdir -p apps/web/dist/game && cp -R apps/game/dist/. apps/web/dist/game/ && cp apps/game/dist/default-bundle.json apps/game/dist/revoltfx-spritesheet.json apps/web/dist/ && cp -R apps/game/dist/spritesheets apps/web/dist/spritesheets",
    "dev:game": "npm run dev -w @open-pixel/game",
    "dev:web": "npm run dev -w @open-pixel/web",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build:vercel && npm run test --workspaces --if-present && npm run test:game:render",
    "test:game:render": "node scripts/check-game-render.mjs",
    "test:game:ai": "node scripts/ai-game-smoke.mjs",
    "test:game:agent": "bash scripts/run-ai-game-e2e.sh",
    "doctor:react": "npx react-doctor@latest ./apps/web/src --no-score --blocking none --yes",
    "db:check": "node scripts/check-supabase-schema.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky",
    "postinstall": "npm --workspace apps/game run postinstall"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css,yml,yaml}": "prettier --write"
  },
  "keywords": [
    "game",
    "web3",
    "rpg",
    "pixel-art",
    "hackathon",
    "rpgjs",
    "supabase"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "patch-package": "^8.0.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1"
  },
  "overrides": {
    "vitest": "4.1.8",
    "@vitest/expect": "4.1.8",
    "@vitest/mocker": "4.1.8",
    "@vitest/pretty-format": "4.1.8",
    "@vitest/runner": "4.1.8",
    "@vitest/snapshot": "4.1.8",
    "@vitest/spy": "4.1.8",
    "@vitest/utils": "4.1.8"
  }
}
