{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/game",
      "destination": "/game/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/game/:path*",
      "destination": "/game/:path*"
    }
  ]
}
